        .table-bordered { width: 100%; border-collapse: collapse; margin-top: 20px; }
        .table-bordered th, .table-bordered td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        .table-bordered th { background-color: #f2f2f2; }
    </style>
</head>

